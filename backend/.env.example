# ---- Deadlock API ----
DEADLOCK_API_BASE=https://api.deadlock-api.com
DEADLOCK_ASSETS_BASE=https://assets.deadlock-api.com

# ---- Local DB ----
DATABASE_URL=sqlite:///./deadlock.db

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CACHE_TTL=3600

# ---- Analysis tuning ----
WINRATE_LOW=0.47
WINRATE_HIGH=0.53
MIN_HERO_MATCHES=50

# ---- Mode filter ----
# Set to "Normal" to exclude Street Brawl/Sandbox/Bots, or leave empty for ALL data.
# The backend tries "game_mode", "match_mode", and "match_modes" as the parameter
# name; the first one that returns non-empty wins. If none work, it falls back to
# unfiltered and adds a notice on the dashboard so you know.
MATCH_MODE=Normal
